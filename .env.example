# 复制为 .env 后填写：cp .env.example .env
# 勿将 .env 提交到 Git。

# --- 服务监听端口（默认 38421，高位端口；可改成任意未占用端口）---
# PORT=38421

# --- 访问本服务用的密钥（客户端 WebSocket / HTTP 请求头 X-API-Key）---
# 留空 = 不校验（仅本机调试）；公网部署请务必设置强随机串。
APP_API_KEY=change-me-to-a-long-random-string

# --- 大模型：OpenAI 兼容（Kimi / OpenAI / vLLM）---
# 默认：前台 + 后台共用下面一组（仍是一套 API，两个 Agent 只是逻辑分工不同）。
# Kimi：https://platform.moonshot.cn
OPENAI_API_KEY=你的_Moonshot_API_Key
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=moonshot-v1-8k
# OPENAI_TEMPERATURE=1

# --- 双 Agent 拆分（可选）：不填则继承 OPENAI_* ---
# 前台：轻量、低延迟、话术丝滑 + 严格执行策略
# FOREGROUND_OPENAI_MODEL=moonshot-v1-8k
# FOREGROUND_OPENAI_TEMPERATURE=1

# 后台：复杂推演 / ToT / 导航（可与前台不同模型，仍同一 Key）
# BACKGROUND_OPENAI_MODEL=kimi-k2.5-turbo-preview
# BACKGROUND_OPENAI_TEMPERATURE=1
# BACKGROUND_MAX_TOKENS=512

# 若后台用另一套 Key 或另一 base_url（例如专线推理）再填：
# BACKGROUND_OPENAI_API_KEY=
# BACKGROUND_OPENAI_BASE_URL=

# 若用 OpenAI 官方，可改为：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 策略缓存：有 Redis 时填；留空则使用进程内内存（仅适合单机开发）---
# REDIS_URL=redis://localhost:6379/0
