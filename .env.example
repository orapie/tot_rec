# 复制为 .env 后填写。勿将 .env 提交到 Git。

# --- 访问本服务用的密钥（客户端 WebSocket / HTTP 请求头 X-API-Key）---
APP_API_KEY=change-me-to-a-long-random-string

# --- 大模型（OpenAI 兼容接口）---
OPENAI_API_KEY=sk-...
# 可选：自建 vLLM / 国内代理时修改
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- 策略缓存：有 Redis 时填；留空则使用进程内内存（仅适合单机开发）---
# REDIS_URL=redis://localhost:6379/0
